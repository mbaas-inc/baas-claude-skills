{
  "version": "7.0",
  "base_url": "/aiapp-baas",
  "common_ref": "references/common.md",
  "fallback": "sections로 부족하면 ref 파일 전체를 읽고, 인증/에러 처리가 필요하면 references/common.md를 추가로 읽으세요",
  "data_flow": {
    "account": {
      "flow": "signup → login → (use app) → logout",
      "note": "번들: login+signup+logout+account_info 항상 함께 구현. auth: true 기능 구현 시 account 번들 포함 필수"
    },
    "messaging": {
      "flow": "폼 입력(이름, 전화번호) → recipient 등록",
      "note": "번들: recipient 단일 기능. 전화번호 형식 검증(validatePhone) 후 등록. 메타데이터로 용도 구분(예약/문의/뉴스레터)"
    },
    "board": {
      "flow": "목록 조회 → post_id 선택 → 상세 조회",
      "note": "번들: notice/faq 각각 목록+상세 함께 구현. 관리자 작성 전용, 일반 사용자는 조회만 가능"
    },
    "dynamic_board": {
      "flow": "board_id 전달 → 게시판 정보(board_settings) 조회 → UI 렌더링 → 목록/상세/작성/댓글/파일/신고",
      "note": "번들: board_list+board_detail+board_create+board_update+board_delete+comments+file_upload+report 항상 함께 구현. board_settings로 UI 조건부 렌더링"
    },
    "survey": {
      "flow": "설문 목록 조회 → share_code로 외부 참여 URL 구성",
      "note": "번들: survey 목록 단일 기능. 응답 제출은 외부 URL(/survey/{share_code})에서 처리"
    }
  },
  "static": [
    {
      "group": "account",
      "ref": "references/account.md",
      "common_sections": ["## 에러 코드"],
      "features": [
        {
          "id": "auth",
          "label": "회원 인증 (로그인/회원가입/로그아웃/계정정보)",
          "auth": false,
          "keywords": ["로그인", "login", "회원가입", "signup", "가입", "로그아웃", "logout", "인증", "계정정보", "내 정보", "프로필"],
          "template": [
            "templates/react/useLogin.tsx",
            "templates/react/useSignup.tsx",
            "templates/react/useLogout.tsx",
            "templates/react/useAccountInfo.tsx"
          ],
          "sections": [
            "## 1. 회원가입 API (프로젝트 회원 전용)",
            "## 2. 로그인 API",
            "## 3. 로그아웃 API",
            "## 4. 계정정보 조회 API",
            "## phone 필드 검증"
          ]
        }
      ]
    },
    {
      "group": "messaging",
      "ref": "references/messaging.md",
      "features": [
        {
          "id": "recipient",
          "label": "연락처 등록",
          "auth": false,
          "keywords": ["연락처", "문의", "예약", "뉴스레터", "구독", "접수", "신청"],
          "template": "templates/react/useRecipient.tsx",
          "sections": [
            "## 1. 발송대상 등록 API",
            "## 2. 전화번호 유효성 검사",
            "## 3. 메타데이터 예시"
          ]
        }
      ]
    },
    {
      "group": "board",
      "ref": "references/board.md",
      "note": "관리자 작성 전용 — 일반 사용자는 조회만",
      "features": [
        {
          "id": "notice",
          "label": "공지사항 목록/상세",
          "auth": false,
          "keywords": ["공지사항", "notice", "공지"],
          "template": "templates/react/useNotice.tsx",
          "sections": [
            "## 1. 게시글 목록 조회 (통합 엔드포인트)",
            "## 2. 게시글 상세 조회"
          ]
        },
        {
          "id": "faq",
          "label": "FAQ 목록/상세",
          "auth": false,
          "keywords": ["FAQ", "자주묻는질문", "질문", "답변"],
          "template": "templates/react/useFaq.tsx",
          "sections": [
            "## 1. 게시글 목록 조회 (통합 엔드포인트)",
            "## 2. 게시글 상세 조회"
          ],
          "note": "목록 응답에 답변(content) 포함 — 상세 조회 없이 Accordion UI 구성 가능"
        }
      ]
    },
    {
      "group": "survey",
      "ref": "references/survey.md",
      "features": [
        {
          "id": "survey",
          "label": "설문조사 목록",
          "auth": false,
          "keywords": ["설문", "설문조사", "만족도"],
          "template": "templates/react/useSurvey.tsx",
          "sections": [
            "## 1. 활성 설문 목록 조회",
            "### 설문 목록 → 참여 흐름"
          ],
          "note": "share_code로 외부 참여 URL 구성 (/survey/{share_code}). 응답 제출은 외부 URL에서 처리."
        }
      ]
    }
  ],
  "dynamic": [
    {
      "group": "dynamic_board",
      "ref": "references/dynamic-board.md",
      "common_sections": ["### 권한 규칙", "### 숨김 처리", "## 에러 코드"],
      "note": "게시판 생성 이후 board_id를 전달받아 사용. 모든 기능 번들로 구현하고 board_settings 응답값으로 UI 조건부 렌더링.",
      "features": [
        {
          "id": "dynamic_board",
          "label": "동적 게시판 (FREE/REVIEW/URL_LINK)",
          "keywords": ["게시판", "게시글 목록", "자유게시판", "리뷰", "링크 목록", "글쓰기", "댓글"],
          "template": [
            "templates/react/useBoard.tsx",
            "templates/react/useComments.tsx"
          ],
          "sections": [
            "## 게시판 정보 JSON",
            "## 1. 게시글 목록 조회 API",
            "## 2. 게시글 작성 API",
            "## 3. 게시글 상세 조회 API",
            "## 4. 게시글 수정 API",
            "## 5. 게시글 삭제 API",
            "## 7. 댓글 목록 조회 API",
            "## 8. 댓글 작성 API",
            "## 9. 댓글 수정 API",
            "## 10. 댓글 삭제 API",
            "## 12. 파일 업로드 API",
            "## 13. 게시글 신고 API",
            "## 14. 댓글 신고 API",
            "### 파일 업로드 플로우",
            "### 댓글 계층 구조"
          ],
          "board_settings_ui": {
            "is_board_enabled": "false → 작성/수정/삭제 버튼 비표시",
            "allow_comment": "false → 댓글 영역 비표시",
            "allow_attachment": "false → 파일 첨부 버튼 비표시",
            "require_login": "true → 비로그인 사용자에게 로그인 유도 (기능 코드는 유지)",
            "categories": "null이 아니면 카테고리 필터 탭/칩 표시"
          },
          "board_type_notes": {
            "URL_LINK": "link_url로 바로 이동 — 상세 조회 불필요, 작성 시 content에 URL 저장",
            "FREE": "일반 자유게시판",
            "REVIEW": "리뷰 게시판"
          }
        }
      ]
    }
  ]
}
